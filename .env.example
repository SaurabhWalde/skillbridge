# ═══════════════════════════════════════════════════════
#  SkillBridge Attendance API — Environment Variables
# ═══════════════════════════════════════════════════════
#
#  SETUP:
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your actual values below
#  3. NEVER commit .env to git (it's in .gitignore)
#
# ═══════════════════════════════════════════════════════

# ──── DATABASE ────
# Get from: https://console.neon.tech → Your Project → Connection Details → Pooled connection
# Format: postgresql://username:password@hostname/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your_password_here@ep-xxxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ──── JWT SECRET KEY ────
# Used to sign JWT tokens. Use any random string.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

# ──── MONITORING API KEY ────
# Extra security layer for Monitoring Officer's scoped token endpoint
# POST /auth/monitoring-token requires this key + valid JWT
MONITORING_API_KEY=your_monitoring_api_key_here